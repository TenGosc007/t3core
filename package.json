{
  "name": "t3core",
  "version": "1.4.3",
  "description": "Reusable TypeScript core library for Tic Tac Toe games",
  "scripts": {
    "build": "rm -rf dist && tsc && tsc-alias",
    "build:watch": "tsc -w && tsc-alias -w",
    "build:tsup": "tsup",
    "build:tsup:watch": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage --run",
    "lint": "eslint ./src/**/*.ts",
    "ts:check": "tsc --noEmit",
    "fallow": "fallow health --coverage coverage/coverage-final.json",
    "publish:dry": "npm run build && npm publish --dry-run",
    "release:tag": "env -i HOME=$HOME PATH=$PATH bash scripts/release.sh",
    "new:release": "env -i HOME=$HOME PATH=$PATH bash scripts/publish-release.sh"
  },
  "keywords": [
    "tic-tac-toe",
    "game",
    "typescript",
    "nodejs"
  ],
  "author": "tengosc",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TenGosc007/t3core.git"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=16.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "fallow": "^2.87.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4"
  }
}
